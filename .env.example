# ============================================
# KochPlan - Environment Variables
# ============================================

# API Konfiguration
VITE_API_URL=https://api.kochplan.app/v1
VITE_API_TIMEOUT=10000

# Push Notifications (VAPID)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Bild-Hosting
VITE_IMAGE_BASE_URL=https://images.kochplan.app
VITE_IMAGE_MAX_SIZE=5242880

# App Konfiguration
VITE_APP_NAME=KochPlan
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://kochplan.app

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_BACKGROUND_SYNC=true

# Cache Konfiguration
VITE_CACHE_VERSION=1
VITE_CACHE_MAX_AGE=2592000

# Development
VITE_DEV_MODE=false
VITE_DEBUG=false
